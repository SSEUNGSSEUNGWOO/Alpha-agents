# ── Binance ──────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true   # 페이퍼 트레이딩 시 true, 라이브 시 false

# ── Glassnode ─────────────────────────────────────────────
GLASSNODE_API_KEY=your_glassnode_api_key

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alpha_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── 트레이딩 설정 ──────────────────────────────────────────
TRADING_SYMBOLS=BTCUSDT,ETHUSDT
TRADING_INTERVAL=15m       # 기준 캔들 타임프레임
PREDICTION_HORIZON=32      # 레이블 생성 미래 봉 수 (32 × 15m = 8시간)
MAX_POSITION_RATIO=0.25    # 단일 포지션 최대 비율
MDD_CIRCUIT_BREAKER=0.15   # 서킷브레이커 MDD 임계값

# ── Phase 2+: newszips 감성 피처 (비활성) ──────────────────
# NEWSZIPS_SUPABASE_URL=your_supabase_url
# NEWSZIPS_SUPABASE_KEY=your_supabase_anon_key
